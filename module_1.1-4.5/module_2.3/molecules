<template>
  <form @submit.prevent="onSubmit" class="form">

    <div class="field">
      <label>Email</label>
      <input
        v-model="email"
        type="email"
        aria-label="email"
        :aria-invalid="!!errors.email"
      />
      <p v-if="errors.email" class="error">{{ errors.email }}</p>
    </div>

    <div class="field">
      <label>Пароль</label>
      <input
        v-model="password"
        type="password"
        aria-label="password"
        :aria-invalid="!!errors.password"
      />
      <p v-if="errors.password" class="error">{{ errors.password }}</p>
    </div>

    <div class="field">
      <label>
        <input type="checkbox" v-model="remember" />
        Запомнить меня
      </label>
    </div>

    <Button variant="primary" size="medium">
      Войти
    </Button>

  </form>
</template>

<script setup>
import { ref } from "vue";
import Button from "../atoms/Button.vue";

const email = ref("");
const password = ref("");
const remember = ref(false);
const errors = ref({});

function validate() {
  const err = {};

  if (!email.value.includes("@")) {
    err.email = "Некорректный email";
  }

  if (!password.value) {
    err.password = "Пароль обязателен";
  }

  errors.value = err;

  return Object.keys(err).length === 0;
}

function onSubmit() {
  if (validate()) {
    console.log("Login:", {
      email: email.value,
      password: password.value,
      remember: remember.value
    });
  }
}
</script>

<style>
.form {
  max-width: 300px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.field {
  display: flex;
  flex-direction: column;
}

.error {
  color: red;
  font-size: 12px;
}
</style>